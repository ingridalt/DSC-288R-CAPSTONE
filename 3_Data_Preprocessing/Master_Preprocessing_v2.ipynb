    "features = [\n",
    "    \"AGEP\", \"WKHP\", \"SCHL_Tier\",\n",
    "    \"SEX\", \"DIS\", \"CIT\", \"MAR\", \"WRK\", \"Born_in_CA\", \"LANX\", \"ForeignBorn\", \"ESR_emp\", \"MIG_recent\",\n",
