    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Disability severity score distribution:\n",
      "disability_score\n",
      "0    1511749\n",
      "1     130064\n",
      "2      56506\n",
      "3      37024\n",
      "4      25049\n",
      "5       9637\n",
