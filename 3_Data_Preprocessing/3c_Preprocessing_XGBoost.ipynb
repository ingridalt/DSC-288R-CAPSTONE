      "DOUT: {1.0: 112975, 2.0: 1661162}\n"
     ]
    }
   ],
   "source": [
    "# Create disability severity score (0-6)\n",
    "# counts how many co-occurring disabilities someone has. A score of 3 just means \"has 3 different disabilities.\" So the model learns that more comorbidities = higher poverty risk\n",
    "disability_cols = ['DEAR', 'DEYE', 'DPHY', 'DREM', 'DDRS', 'DOUT']\n",
    "\n",
    "# Check raw values\n",
    "for col in disability_cols:\n",
    "    print(f'{col}: {df[col].value_counts().sort_index().to_dict()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "metadata": {
    "ExecuteTime": {
